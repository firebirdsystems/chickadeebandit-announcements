{
  "id": "announcements",
  "name": "Announcements",
  "version": "1.0.0",
  "description": "Post household announcements with admin approval, expiration, and notification support.",
  "entrypoint": "index.html",
  "runtime": "static",
  "storage": "db",
  "category": "general",
  "tags": ["announcements", "notices", "admin"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "row_policies": {
    "announcements": {
      "kind": "owner_or_visibility",
      "member_column": "author_id",
      "visibility_column": "status",
      "everyone_values": ["pending", "approved", "archived"],
      "write_owner_only": false
    },
    "acknowledgements": {
      "kind": "owner_only",
      "member_column": "member_id"
    }
  },
  "publishes": ["announcement.submitted", "announcement.approved"],
  "alert_on": ["announcement.approved"],
  "nav": {
    "label": "Announcements"
  },
  "widget": {
    "label": "Announcements",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 5242880
  },
  "icon": "📢",
  "ai_access": {
    "allowed": true,
    "mode": "read_write",
    "db_exports": ["active_announcements", "pending_announcements"],
    "db_mutations": ["extend_expiry"],
    "db_inserts": ["create_announcement"]
  }
}
