{
  "id": "announcements",
  "name": "Announcements",
  "version": "1.0.0",
  "description": "Post household announcements with admin approval, expiration, and notification support — including optional email to every member.",
  "entrypoint": "index.html",
  "runtime": "static",
  "storage": "db",
  "category": "general",
  "tags": ["announcements", "notices", "admin"],
  "contexts": ["household", "shared_space", "shared_space.roster"],
  "data_access": {
    "reads": ["family.members", "family.groups"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "row_policies": {
    "announcements": {
      "kind": "owner_or_visibility",
      "member_column": "author_id",
      "visibility_column": "status",
      "everyone_values": ["pending", "approved", "archived"],
      "privileged_groups": [{ "settings_table": "settings", "settings_key": "moderator_group_id" }],
      "write_owner_only": true
    },
    "approvals": {
      "kind": "inherit_visibility",
      "fk_column": "announcement_id",
      "parent_table": "announcements",
      "writer_column": "approved_by",
      "insert_privileged_only": true
    },
    "acknowledgements": {
      "kind": "owner_only",
      "member_column": "member_id",
      "max_per_member": {
        "member_column": "member_id",
        "scope_columns": ["announcement_id"],
        "limit": 1
      }
    },
    "settings": {
      "kind": "app_config"
    }
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": ["moderator_group_id"]
  },
  "publishes": ["announcement.submitted", "announcement.approved"],
  "alert_on": ["announcement.approved"],
  "publish_acls": {
    "announcement.submitted": { "require_role": "adult" },
    "announcement.approved":  { "require_role": "adult" }
  },
  "notification_acls": {
    "send": {
      "require_group_setting": { "settings_table": "settings", "settings_key": "moderator_group_id" }
    }
  },
  "nav": {
    "label": "Announcements"
  },
  "widget": {
    "label": "Announcements",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 5242880
  },
  "icon": "📢",
  "ai_access": {
    "allowed": true,
    "mode": "read_write",
    "db_exports": ["active_announcements", "pending_announcements"],
    "db_mutations": ["extend_expiry"],
    "db_inserts": ["create_announcement"]
  }
}
